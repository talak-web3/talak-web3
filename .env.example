# ==============================================================================
# talak-web3 — Environment Configuration
# ==============================================================================

# Core Infrastructure
# ------------------------------------------------------------------------------
# Redis connection string (Mandatory for production atomicity)
REDIS_URL=redis://localhost:6379

# Port for the hono-backend service
PORT=8787

# NODE_ENV (development | production)
NODE_ENV=development

# Authentication & Security
# ------------------------------------------------------------------------------
# Secret key for JWT signing (Minimum 32 characters recommended)
JWT_SECRET=your-jwt-secret-min-32-chars

# Authoritative domain for SIWE message verification
SIWE_DOMAIN=localhost:8787

# Shared CORS Allowed Origins (Comma-separated)
# Must match the frontend origin exactly (No wildcards in production)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
# ------------------------------------------------------------------------------
# Options: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# Service Adapters (Optional)
# ------------------------------------------------------------------------------

# Ceramic Network
# Seed for deterministic decentralized identity
CERAMIC_SEED=

# Pinata / IPFS
# JWT for pinning and fetching from IPFS
PINATA_JWT=

# Tableland
# Private key for mutating decentralized relational data
TABLELAND_PRIVATE_KEY=

# Bundler / Paymaster (ERC-4337)
# ------------------------------------------------------------------------------
# Key for signing paymaster sponsorship requests
PAYMASTER_PRIVATE_KEY=

# Alchemy / Pimlico / Biconomy API Keys
BUNDLER_API_KEY=
