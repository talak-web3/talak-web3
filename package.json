{
  "name": "@talak-web3/monorepo",
  "version": "0.0.1",
  "private": true,
  "homepage": "https://github.com/dagimabebe/talak-web3#readme",
  "bugs": {
    "url": "https://github.com/dagimabebe/talak-web3/issues"
  },
  "license": "MIT",
  "author": "Dagim Abebe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dagimabebe/talak-web3.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/dagimabebe"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "preinstall": "node ./scripts/enforce-package-manager.cjs",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --report-unused-disable-directives",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "turbo run test",
    "test:unit": "vitest run --exclude '**/integration/**' --exclude '**/e2e/**'",
    "test:integration": "vitest run packages/**/src/**/integration/**/*.ts",
    "test:e2e": "vitest run apps/**/e2e/**/*.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:smoke": "pnpm --filter @talak-web3/smoke-test test",
    "ci:fast": "turbo run build typecheck test",
    "dev": "turbo run dev",
    "clean": "turbo run clean",
    "check:deps": "tsx scripts/check-deps.ts",
    "audit:full": "pnpm audit",
    "audit:runtime": "pnpm audit --prod",
    "docs:dev": "turbo run dev --filter=@talak-web3/docs",
    "docs:build": "turbo run build --filter=@talak-web3/docs",
    "docs:start": "turbo run start --filter=@talak-web3/docs",
    "docs:typecheck": "turbo run typecheck --filter=@talak-web3/docs",
    "docs:lint": "turbo run lint --filter=@talak-web3/docs",
    "docs:test": "turbo run test --filter=@talak-web3/docs",
    "lint:packages": "turbo run lint:packages",
    "docs:api": "typedoc",
    "bump": "bumpp --recursive --no-push --execute \"pnpm install --force\"",
    "release:prepare": "bumpp --recursive --no-commit --no-push --no-tag --execute \"pnpm install --force\"",
    "release": "bumpp --recursive --no-push --all --execute \"pnpm install --force\"",
    "release:beta": "bumpp prerelease --preid beta --recursive --no-push --execute \"pnpm install --force\""
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^4.1.5",
    "bumpp": "^10.4.1",
    "esbuild": "0.28.1",
    "husky": "^9.1.7",
    "js-yaml": "4.3.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "publint": "^0.3.17",
    "redis": "^5.12.1",
    "rimraf": "^6.1.3",
    "tsdown": "catalog:",
    "tsx": "^4.23.1",
    "turbo": "^2.9.14",
    "typescript": "catalog:",
    "vite": "8.1.5",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.0"
}
