{
  "name": "talak-web3",
  "version": "1.1.0",
  "description": "A comprehensive Web3 SDK for blockchain development",
  "keywords": [
    "blockchain",
    "crypto",
    "dapp",
    "ethereum",
    "smart-contracts",
    "wallet",
    "web3"
  ],
  "homepage": "https://github.com/dagimabebe/talak-web3#readme",
  "bugs": {
    "url": "https://github.com/dagimabebe/talak-web3/issues"
  },
  "license": "MIT",
  "author": "Dagim Abebe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dagimabebe/talak-web3.git",
    "directory": "packages/talak-web3"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./multichain": {
      "import": {
        "types": "./dist/multichain.d.ts",
        "default": "./dist/multichain.js"
      },
      "require": {
        "types": "./dist/multichain.d.cts",
        "default": "./dist/multichain.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./nextjs": {
      "import": {
        "types": "./dist/nextjs.d.ts",
        "default": "./dist/nextjs.js"
      },
      "require": {
        "types": "./dist/nextjs.d.cts",
        "default": "./dist/nextjs.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "pnpm rimraf dist",
    "pack:check": "npm pack --dry-run",
    "lint:package": "publint run --strict --pack false",
    "lint:types": "attw --profile node16 --pack ."
  },
  "dependencies": {
    "@talak-web3/client": "workspace:*",
    "@talak-web3/config": "workspace:*",
    "@talak-web3/core": "workspace:*",
    "@talak-web3/hooks": "workspace:*",
    "@talak-web3/rpc": "workspace:*",
    "ioredis": "^5.0.0",
    "jose": "^6.0.0",
    "viem": "catalog:",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@talak-web3/types": "workspace:*",
    "next": "16.2.11"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0 || ^16.2.11",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
