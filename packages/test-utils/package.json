{
  "name": "@talak-web3/test-utils",
  "version": "1.0.11",
  "description": "Testing utilities for talak-web3 packages",
  "homepage": "https://github.com/dagimabebe/talak-web3/tree/main/packages/test-utils#readme",
  "bugs": {
    "url": "https://github.com/dagimabebe/talak-web3/issues"
  },
  "license": "MIT",
  "author": "Dagim Abebe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dagimabebe/talak-web3.git",
    "directory": "packages/test-utils"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "pnpm rimraf dist"
  },
  "dependencies": {
    "@talak-web3/auth": "workspace:*",
    "@talak-web3/core": "workspace:*",
    "@talak-web3/errors": "workspace:*",
    "@talak-web3/types": "workspace:*",
    "jose": "^6.2.2",
    "viem": "2.48.1"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
