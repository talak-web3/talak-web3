{
  "name": "@talak-web3/auth",
  "version": "1.0.2",
  "type": "module",
  "author": "Dagim Abebe",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./stores": {
      "types": "./dist/stores/index.d.ts",
      "import": "./dist/stores/index.js",
      "require": "./dist/stores/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@talak-web3/errors": "workspace:*",
    "@talak-web3/types": "workspace:*",
    "ioredis": "^5.10.1",
    "jose": "^5.9.6",
    "viem": "^2.21.54"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  }
}
