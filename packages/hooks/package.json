{
  "name": "@talak-web3/hooks",
  "version": "1.1.0",
  "description": "React hooks for talak-web3. Wallet connection, balance, and message signing.",
  "homepage": "https://github.com/dagimabebe/talak-web3/tree/main/packages/hooks#readme",
  "bugs": {
    "url": "https://github.com/dagimabebe/talak-web3/issues"
  },
  "license": "MIT",
  "author": "Dagim Abebe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dagimabebe/talak-web3.git",
    "directory": "packages/hooks"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./use-account": {
      "types": "./dist/hooks/use-account.d.ts",
      "default": "./dist/hooks/use-account.js"
    },
    "./use-balance": {
      "types": "./dist/hooks/use-balance.d.ts",
      "default": "./dist/hooks/use-balance.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "oxlint .",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint:package": "publint run --strict --pack false",
    "lint:types": "attw --profile esm-only --pack ."
  },
  "dependencies": {
    "@talak-web3/client": "workspace:*",
    "@talak-web3/types": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.0.0 || ^19.0.0",
    "@types/react-dom": "^18.0.0 || ^19.0.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  }
}
