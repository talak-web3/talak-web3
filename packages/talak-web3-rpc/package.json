{
  "name": "@talak-web3/rpc",
  "version": "1.0.10",
  "homepage": "https://github.com/dagimabebe/talak-web3/tree/main/packages/talak-web3-rpc#readme",
  "bugs": {
    "url": "https://github.com/dagimabebe/talak-web3/issues"
  },
  "license": "MIT",
  "author": "Dagim Abebe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dagimabebe/talak-web3.git",
    "directory": "packages/talak-web3-rpc"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --tsconfig tsconfig.tsup.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@talak-web3/errors": "workspace:*",
    "@talak-web3/types": "workspace:*",
    "@talak-web3/utils": "workspace:*"
  }
}
