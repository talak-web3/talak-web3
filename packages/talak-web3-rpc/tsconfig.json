{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "paths": {
      "@talak-web3/core": ["../talak-web3-core/src"]
    }
  },
  "references": [
    { "path": "../talak-web3-errors" },
    { "path": "../talak-web3-types" },
    { "path": "../talak-web3-utils" },
    { "path": "../talak-web3-core" }
  ],
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts"]
}
