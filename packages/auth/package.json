{
  "name": "@talak-web3/auth",
  "version": "1.1.0",
  "homepage": "https://github.com/dagimabebe/talak-web3/tree/main/packages/auth#readme",
  "bugs": {
    "url": "https://github.com/dagimabebe/talak-web3/issues"
  },
  "license": "MIT",
  "author": "Dagim Abebe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dagimabebe/talak-web3.git",
    "directory": "packages/auth"
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "tsdown.config.ts",
    "tsconfig.json"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./stores": {
      "types": "./dist/stores/index.d.ts",
      "import": "./dist/stores/index.js",
      "require": "./dist/stores/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "pnpm rimraf dist"
  },
  "dependencies": {
    "@talak-web3/errors": "workspace:*",
    "@talak-web3/types": "workspace:*",
    "ioredis": "5.10.1",
    "jose": "6.2.2",
    "viem": "2.48.1"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/redis": "^4.0.0"
  }
}
