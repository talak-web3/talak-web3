{
  "name": "@talak-web3/rpc",
  "version": "1.1.0",
  "homepage": "https://github.com/dagimabebe/talak-web3/tree/main/packages/rpc#readme",
  "bugs": {
    "url": "https://github.com/dagimabebe/talak-web3/issues"
  },
  "license": "MIT",
  "author": "Dagim Abebe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dagimabebe/talak-web3.git",
    "directory": "packages/rpc"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "pnpm rimraf dist",
    "lint:package": "publint run --strict --pack false",
    "lint:types": "attw --profile esm-only --pack ."
  },
  "dependencies": {
    "@talak-web3/errors": "workspace:*",
    "@talak-web3/types": "workspace:*",
    "@talak-web3/utils": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "catalog:"
  }
}
